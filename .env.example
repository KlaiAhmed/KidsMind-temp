# False enables dev auth bypass and relaxed rate limits. Set to True only in production.
IS_PROD=False

# Public API bind
API_BIND_HOST=0.0.0.0
API_PORT=8000

# Local-only debug ports (only used when docker-compose.debug.yml is loaded)
AI_PORT=8001
STT_PORT=8002
DB_PORT=5432
STORAGE_API_PORT=9000
STORAGE_CONSOLE_PORT=9001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_PORT=9121

# Upstream service URLs (consumed by core-api only)
AI_SERVICE_URL=http://ai-service:8000
STT_SERVICE_URL=http://stt-service:8000

# Database
DB_USER=admin
DB_PASSWORD=secretpassword
DB_NAME=kidsmind_db

# Storage
STORAGE_ROOT_USER=admin
STORAGE_ROOT_PASSWORD=secretpassword

# Cache
CACHE_PASSWORD=secretpassword

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=secretpassword

# Docker Compose file selection - controls which compose files are loaded
# Docker reads this variable automatically. Use the correct separator:
#   ":" on Linux/macOS, ";" on Windows
# Uncomment ONE preset below to set your environment:
#   development: base + override (local dev with hot reload)
#   debug: base + override + debug (exposes internal services to localhost)
#   production: base only (no override, no debug ports - NEVER use override/debug in production)

COMPOSE_FILE=docker-compose.yml;docker-compose.override.yml
# COMPOSE_FILE=docker-compose.yml;docker-compose.override.yml;docker-compose.debug.yml
# COMPOSE_FILE=docker-compose.yml


# Logging level for all services.
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
# DEBUG:    full traces, SQL queries, request internals — best for chasing a specific bug
# INFO:     service events, request summaries — good default for dev and production
# WARNING:  only recoverable issues and above — use when INFO is too noisy in production
# ERROR:    failures only
LOG_LEVEL=INFO



