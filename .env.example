# =============================================================================
# KidsMind Root Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.

# =============================================================================
# APP & RUNTIME
# =============================================================================

# Production mode toggle (False enables dev auth bypass and relaxed rate limits)
IS_PROD=False

# Global logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# NETWORK & PORTS
# =============================================================================

# Public API bind configuration
API_BIND_HOST=0.0.0.0
API_PORT=8000

# Debug ports (only used when docker-compose.debug.yml is loaded)
VOICE_PORT=8002
DB_PORT=5432
STORAGE_API_PORT=9000
STORAGE_CONSOLE_PORT=9001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_PORT=9121

# =============================================================================
# DOCKER COMPOSE
# =============================================================================

# Compose file selection (use ";" on Windows, ":" on Linux/macOS)
# Development: docker-compose.yml;docker-compose.override.yml
# Debug: docker-compose.yml;docker-compose.override.yml;docker-compose.debug.yml
# Production: docker-compose.yml
COMPOSE_FILE=docker-compose.yml;docker-compose.override.yml

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

DB_USER=your_postgres_username
DB_PASSWORD=your_postgres_password
DB_NAME=your_database_name

# =============================================================================
# CACHE (Redis)
# =============================================================================

CACHE_PASSWORD=your_redis_password

# =============================================================================
# OBJECT STORAGE (MinIO)
# =============================================================================

STORAGE_ROOT_USER=your_minio_root_username
STORAGE_ROOT_PASSWORD=your_minio_root_password

# =============================================================================
# MONITORING (Grafana)
# =============================================================================

GRAFANA_ADMIN_USER=your_grafana_admin_username
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password
