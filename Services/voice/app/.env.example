# =============================================================================
# KidsMind VOICE (Speech-to-Text, Text-to-Speech) Service Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.

# =============================================================================
# APP & RUNTIME
# =============================================================================

# Required when IS_PROD=False — confirms dev mode is intentional
EXPLICIT_DEV_MODE=true

# CORS allowed origins
CORS_ORIGINS=["*"]

# =============================================================================
# SECURITY & SERVICE AUTH
# =============================================================================

# Shared secret for inter-service authentication (must match API service)
SERVICE_TOKEN=your_64_char_random_hex_service_token

# =============================================================================
# WHISPER MODEL CONFIGURATION
# =============================================================================

# Execution mode: cpu (compatible, slower) or gpu (requires CUDA, faster)
WHISPER_MODE=gpu

# Model size: tiny, base, small, medium, large-v3-turbo, large-v3
# Larger models = better accuracy, higher resource usage
WHISPER_MODEL=large-v3-turbo

# Number of concurrent transcription workers
WHISPER_NUM_WORKERS=2

# CPU threads per file (only used when WHISPER_MODE=cpu)
WHISPER_CPU_THREADS=4

# =============================================================================
# TEXT-TO-SPEECH PROVIDER
# =============================================================================

# Provider switch for TTS synthesis. Currently: gtts
TTS_PROVIDER=gtts

# Default TTS language when the request omits one
TTS_DEFAULT_LANGUAGE=en

# =============================================================================
# HUGGING FACE (Optional)
# =============================================================================
# Hugging Face read token for increased rate limits on model downloads.
HF_TOKEN=hf_your_huggingface_token_here