# =============================================================================
# KidsMind STT (Speech-to-Text) Service Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.
# This file configures the Faster-Whisper transcription service.


# =============================================================================
# APP & RUNTIME
# =============================================================================

# Required when IS_PROD=False — confirms dev mode is intentional.
# A safety confirmation for THIS service only.
EXPLICIT_DEV_MODE=true

# CORS allowed origins. In production, set to specific domains.
CORS_ORIGINS=["*"]


# =============================================================================
# SECURITY & SERVICE AUTH
# =============================================================================

# Shared secret for inter-service authentication.
# Always required — must match SERVICE_TOKEN in API service.
SERVICE_TOKEN=your_64_char_random_hex_service_token


# =============================================================================
# WHISPER MODEL CONFIGURATION
# =============================================================================

# Execution mode: cpu (compatible, slower) or gpu (requires CUDA, faster)
WHISPER_MODE=gpu

# Model size. Options: tiny, base, small, medium, large-v3-turbo, large-v3
# Larger models = better accuracy, higher resource usage
WHISPER_MODEL=large-v3-turbo

# Number of concurrent transcription workers.
# More workers = parallel processing, but 2x workers = 2x resource usage.
WHISPER_NUM_WORKERS=2

# CPU threads per file (only used when WHISPER_MODE=cpu)
WHISPER_CPU_THREADS=4


# =============================================================================
# HUGGING FACE (Optional)
# =============================================================================

# Hugging Face read token for increased rate limits on model downloads.
# Optional but recommended to avoid download rate limits.
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_huggingface_token_here
