# Core API Service Configuration

# Required when IS_PROD=False — confirms auth bypass is intentional.
# A safety confirmation for THIS service only.
EXPLICIT_DEV_MODE=true

# AUTH token for basic security
SERVICE_TOKEN=your_long_random_hex_string_here

# CORS configuration (in production, set to specific allowed origins)
CORS_ORIGINS=["*"]

# 10 * 1024 * 1024 = 10 MB
MAX_SIZE=10485760

RATE_LIMIT=5/minute

# JWT Token settings
SECRET_ACCESS_KEY=your_long_random_hex_string_here
SECRET_REFRESH_KEY=your_long_random_hex_string_here
DUMMY_HASH=your_long_random_hex_string_here
JWT_AUD_WEB=web-client
JWT_AUD_MOBILE=mobile-client

# Cookie settings
ACCESS_TOKEN_EXPIRE_SECONDS=900 # 15 minutes
REFRESH_TOKEN_WEB_EXPIRE_SECONDS=604800 # 7 days
REFRESH_TOKEN_MOBILE_EXPIRE_SECONDS=2592000 # 30 days
REFRESH_TOKEN_EXPIRE_SECONDS=604800 # 1 week
CSRF_TOKEN_EXPIRE_SECONDS=604800 # 1 week
# Set to your domain in production, e.g. kidsmind.com. Leave blank for localhost.
COOKIE_DOMAIN=

# Auth controls
AUTH_LOGIN_RATE_LIMIT=5/15minute
AUTH_REGISTER_RATE_LIMIT=3/hour
AUTH_REFRESH_RATE_LIMIT=10/minute
CAPTCHA_ENABLED=True
LOGIN_CAPTCHA_THRESHOLD=3
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_MINUTES=15
MOBILE_MAX_ACTIVE_SESSIONS=10
APP_ATTESTATION_ENABLED=False
APP_ATTESTATION_STRICT=False
RL_STORE_UNAVAILABLE_MODE=fail_open

# Initial super admin bootstrap (created once if missing)
SUPER_ADMIN_EMAIL=superadmin@kidsmind.com
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Frontend
WEB_CLIENT_URL="http://localhost:5173"
MOBILE_CLIENT_URL="http://localhost:8081"

# AI Model credentials
MODEL_NAME=OpenAI's model name here
BASE_URL=url_here
API_KEY=your_secret_here

# Guard API credentials (OpenAI text moderation — production)
GUARD_MODEL_NAME=API's moderation model name here
GUARD_API_URL=url_here
GUARD_API_KEY=your_secret_here

# Dev Guard API credentials (Sightengine — development only)
DEV_API_USER=your_user_id_here
DEV_GUARD_API_URL=url_here
DEV_GUARD_API_KEY=your_secret_here

# AI Cache & History
MAX_HISTORY_MESSAGES=40
MAX_LOADED_HISTORY_MESSAGES=10
MAX_HISTORY_TOKENS=1500
HISTORY_TTL_SECONDS=3600
