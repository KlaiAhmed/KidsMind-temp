# =============================================================================
# KidsMind Core API Service Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.

# =============================================================================
# APP & RUNTIME
# =============================================================================

# Required when IS_PROD=False — confirms dev mode is intentional
EXPLICIT_DEV_MODE=true

# CORS allowed origins (e.g., ["https://app.example.com"])
CORS_ORIGINS=["*"]

# Maximum upload file size in bytes (10 MB)
MAX_SIZE=10485760

# HTTP client timeouts (seconds)
HTTP_CLIENT_CONNECT_TIMEOUT=5.0
HTTP_CLIENT_READ_TIMEOUT=60.0
HTTP_CLIENT_WRITE_TIMEOUT=10.0
HTTP_CLIENT_POOL_TIMEOUT=5.0

# =============================================================================
# SECURITY & SERVICE AUTH
# =============================================================================

# Shared secret for inter-service authentication
SERVICE_TOKEN=your_64_char_random_hex_service_token

# =============================================================================
# AUTHENTICATION (JWT)
# =============================================================================

# JWT signing keys (use cryptographically secure random strings)
SECRET_ACCESS_KEY=your_64_char_random_hex_access_key
SECRET_REFRESH_KEY=your_64_char_random_hex_refresh_key

# Dummy hash for timing-safe comparison (prevents user enumeration)
DUMMY_HASH=your_64_char_random_hex_dummy_hash

# JWT audience identifiers
JWT_AUD_WEB=web-client
JWT_AUD_MOBILE=mobile-client

# Token lifetimes (seconds)
ACCESS_TOKEN_EXPIRE_SECONDS=900              # 15 minutes
REFRESH_TOKEN_WEB_EXPIRE_SECONDS=604800      # 7 days
REFRESH_TOKEN_MOBILE_EXPIRE_SECONDS=2592000  # 30 days
REFRESH_TOKEN_EXPIRE_SECONDS=604800          # 1 week (fallback)
CSRF_TOKEN_EXPIRE_SECONDS=604800             # 1 week

# Cookie domain (leave blank for localhost)
COOKIE_DOMAIN=

# =============================================================================
# RATE LIMITING & BRUTE FORCE PROTECTION
# =============================================================================

# General rate limit (requests per time window)
RATE_LIMIT=5/minute

# Captcha and lockout settings
CAPTCHA_ENABLED=True
LOGIN_CAPTCHA_THRESHOLD=3      # Failed attempts before captcha required
LOGIN_LOCKOUT_THRESHOLD=5      # Failed attempts before account lockout
LOGIN_LOCKOUT_MINUTES=15       # Lockout duration in minutes

# Mobile session limits
MOBILE_MAX_ACTIVE_SESSIONS=10

# Rate limit store behavior when Redis is unavailable
RL_STORE_UNAVAILABLE_MODE=fail_open

# =============================================================================
# APP ATTESTATION (Mobile Security)
# =============================================================================

# Enable iOS/Android app attestation verification
APP_ATTESTATION_ENABLED=False

# =============================================================================
# BOOTSTRAP ADMIN
# =============================================================================

# Initial super admin credentials (created once if missing)
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=YourSecurePassword123!

# =============================================================================
# FRONTEND URLs (for CORS and redirects)
# =============================================================================

WEB_CLIENT_URL=http://localhost:5173
MOBILE_CLIENT_URL=http://localhost:8081

# =============================================================================
# AI / LLM PROVIDER
# =============================================================================

# Primary AI model configuration
MODEL_NAME=gpt-4o-mini
BASE_URL=https://api.openai.com/v1
API_KEY=sk-your_openai_api_key_here

# LLM tuning parameters
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1500
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Max LLM response tokens per child age group (JSON)
LLM_AGE_GROUP_MAX_TOKENS={"3-6": 300, "7-11": 600, "12-15": 1000}

# AI operation timeouts (seconds)
AI_INVOKE_TIMEOUT_SECONDS=70
AI_QUIZ_TIMEOUT_SECONDS=90

# Default language for child AI interactions (ar, en, es, fr, it, zh)
DEFAULT_LANGUAGE=en

# =============================================================================
# CONTENT MODERATION (Guard API)
# =============================================================================

# Production moderation provider (e.g., OpenAI Moderation API)
GUARD_MODEL_NAME=text-moderation-latest
GUARD_API_URL=https://api.openai.com/v1/moderations
GUARD_API_KEY=sk-your_openai_api_key_here

# Development moderation provider (e.g., Sightengine)
DEV_GUARD_API_URL=https://api.sightengine.com/1.0/text.json
DEV_API_USER=your_sightengine_user_id
DEV_GUARD_API_KEY=your_sightengine_api_key

# Dev moderation HTTP timeouts (seconds)
DEV_GUARD_CONNECT_TIMEOUT=5.0
DEV_GUARD_READ_TIMEOUT=10.0
DEV_GUARD_WRITE_TIMEOUT=5.0
DEV_GUARD_POOL_TIMEOUT=3.0

# =============================================================================
# CONVERSATION HISTORY & SESSION MEMORY
# =============================================================================

# HISTORY = Persisted conversation data in Postgres (long-term storage)
# MEMORY = Active conversation context in Redis (short-term LLM context)

# Maximum tokens from MEMORY to include in LLM context
MAX_SESSION_MEMORY_TOKENS=1500

# Redis cache TTL for MEMORY (seconds)
SESSION_MEMORY_TTL_SECONDS=14400
